        "@vitejs/plugin-react": "^3.1.0",
        "autoprefixer": "^10.4.13",
        "postcss": "^8.4.21",
        "prettier": "^2.8.3",
        "prettier-plugin-tailwindcss": "^0.2.2",
        "tailwindcss": "^3.2.4",
        "typescript": "^4.9.3",
